# CoWrite Backend — environment variables
# Copy this to .env and fill in the values

# Server port (Render sets this automatically to 10000)
PORT=3001

# Groq API key for AI features — get free at https://console.groq.com
# Without this, the AI panel uses smart local fallback responses (still works!)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Allowed CORS origin — set to your Vercel frontend URL in production
# Use * during development
FRONTEND_URL=https://your-app.vercel.app

# Storage directory for document data
# On Render, set this to /data/storage (persistent disk mount)
# Locally, leave blank to use ./storage
STORAGE_DIR=
